{
  "version": 2,
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(css|js|assets|favicon.ico|favicon.png)/(.*)",
      "dest": "/public/$1/$2"
    },
    {
      "src": "/api/(.*)",
      "dest": "api/index.ts"
    },
    {
      "src": "/([^/\\.]+)",
      "dest": "api/index.ts"
    },
    {
      "src": "/$",
      "dest": "/public/index.html"
    }
  ]
}
