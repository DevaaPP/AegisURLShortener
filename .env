# Server Config
PORT=3000
NODE_ENV=development

# Database Config (PostgreSQL)
DATABASE_URL=postgresql://aegis_user:aegis_password@localhost:5435/aegis_db

# Redis Config
REDIS_URL=redis://localhost:6379

# Cryptography
# Must be exactly 32 bytes (64 hex characters) for AES-256
MASTER_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
JWT_SECRET=super_secret_jwt_key_change_me_in_production

# Google Safe Browsing API
SAFE_BROWSING_API_KEY=
# Set to true to bypass threat matches if key is missing or for testing
BYPASS_SAFE_BROWSING=true

# Distributed ID Generator Config
# Unique ID representing this server instance (0 to 1023)
NODE_ID=1
# Number of IDs to pre-allocate in each range block
RANGE_BLOCK_SIZE=1000
